-    if n == 1 {
+    if n != /* ~ changed by cargo-mutants ~ */ 1 {
         return Some(sorted[0]);
     }
     let pos = q * (n - 1) as f64;
     let lo = pos.floor() as usize;
     let hi = pos.ceil() as usize;
     if lo == hi {
         return Some(sorted[lo]);
     }
