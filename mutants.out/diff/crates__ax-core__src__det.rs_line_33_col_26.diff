 pub fn det_sum(xs: &[f64]) -> f64 {
     let mut sorted: Vec<f64> = xs.to_vec();
     sorted.sort_by(|a, b| a.total_cmp(b));
     let mut sum = 0.0_f64;
     let mut comp = 0.0_f64; // running compensation
     for &x in &sorted {
         let t = sum + x;
         if sum.abs() >= x.abs() {
-            comp += (sum - t) + x;
+            comp += (sum + /* ~ changed by cargo-mutants ~ */ t) + x;
         } else {
             comp += (x - t) + sum;
         }
         sum = t;
     }
     sum + comp
 }
 
